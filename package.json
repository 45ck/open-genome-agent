{
  "name": "open-genome-agent",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first DNA and VCF analysis copilot for evidence-bound genomics workflows, variant interpretation, and confidence-tiered reporting.",
  "homepage": "https://github.com/45ck/open-genome-agent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/45ck/open-genome-agent.git"
  },
  "bugs": {
    "url": "https://github.com/45ck/open-genome-agent/issues"
  },
  "keywords": [
    "genomics",
    "bioinformatics",
    "dna",
    "vcf",
    "variant-interpretation",
    "pharmacogenomics",
    "local-first",
    "privacy",
    "agents",
    "codex",
    "claude"
  ],
  "scripts": {
    "build": "python scripts/build_all.py",
    "test": "python -m unittest discover -s tests -p \"test_*.py\"",
    "ci": "npm run build && npm run test",
    "issues:export": "bd export --no-memories -o .beads/issues.jsonl",
    "quality:fast": "noslop check --tier=fast --pack python --no-spell",
    "quality:slow": "noslop check --tier=slow --pack python"
  },
  "devDependencies": {
    "@45ck/agent-docs": "github:45ck/agent-docs",
    "@45ck/noslop": "^1.0.0"
  }
}
