{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InterpretationCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "module",
    "source_name",
    "source_class",
    "confidence_bucket",
    "query",
    "expected_assertion",
    "evidence_requirements"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "module": {
      "type": "string",
      "enum": [
        "clinvar",
        "pgx",
        "prs",
        "functional"
      ]
    },
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "source_class": {
      "type": "string",
      "enum": [
        "direct_variant_assertion",
        "pharmacogenomics_guideline",
        "polygenic_score",
        "functional_assay"
      ]
    },
    "confidence_bucket": {
      "type": "string",
      "enum": [
        "strong",
        "plausible",
        "hypothesis",
        "unsupported"
      ]
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "expected_assertion": {
      "type": "string",
      "minLength": 1
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
