{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RawInputManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_id",
    "sample_id",
    "input_kind",
    "reference_build",
    "inputs"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "sample_id": {
      "type": "string",
      "minLength": 1
    },
    "input_kind": {
      "type": "string",
      "enum": [
        "fastq",
        "bam",
        "cram"
      ]
    },
    "reference_build": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "r1",
              "r2",
              "bam",
              "cram",
              "index"
            ]
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
