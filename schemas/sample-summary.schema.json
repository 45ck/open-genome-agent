{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SampleSummary",
  "type": "object",
  "required": [
    "sample_id"
  ],
  "properties": {
    "sample_id": {
      "type": "string"
    },
    "sex_call": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "XX",
        "XY",
        "ambiguous",
        null
      ]
    },
    "sample_count": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "contig_style": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "chr",
        "plain",
        "mixed",
        null
      ]
    },
    "coverage_summary": {
      "type": [
        "object",
        "null"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
